{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DreamCatcher",
  "version": "0.1.0",
  "identifier": "com.theor.dreamcatcher",
  "build": {
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DreamCatcher",
        "width": 1480,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}


